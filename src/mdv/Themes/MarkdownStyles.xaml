<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                    xmlns:markdig="clr-namespace:Markdig.Wpf;assembly=Markdig.Wpf">

    <!--
        Overrides for Markdig.Wpf's default styles (defined in its Themes/generic.xaml).
        These are keyed with the same ComponentResourceKeys exposed by Markdig.Wpf.Styles,
        so application-level resource lookup finds them first and replaces the defaults.

        Headings  -> Cambria (serif)
        Body/lists -> Segoe UI (sans-serif), inherited from the document style.

        Each FontFamily lists "Segoe UI Emoji" as a trailing fallback. Cambria and
        Segoe UI carry no emoji glyphs, and WPF's default text fallback only reaches
        Segoe UI Symbol — which lacks emoji added after Unicode 6.x (e.g. 🟠 U+1F7E0),
        rendering them as a missing-glyph "?". Naming Segoe UI Emoji explicitly lets
        WPF resolve those newer codepoints. See issue #7.
    -->

    <!-- Overall document: sans-serif body font + comfortable reading metrics -->
    <Style x:Key="{x:Static markdig:Styles.DocumentStyleKey}" TargetType="{x:Type FlowDocument}">
        <Setter Property="FontFamily" Value="Segoe UI, Segoe UI Emoji" />
        <Setter Property="FontSize" Value="15" />
        <Setter Property="LineHeight" Value="22" />
        <Setter Property="PagePadding" Value="32,24,32,24" />
        <Setter Property="TextAlignment" Value="Left" />
    </Style>

    <!-- Headings: serif (Cambria), bold, descending sizes -->
    <Style x:Key="{x:Static markdig:Styles.Heading1StyleKey}" TargetType="{x:Type Paragraph}">
        <Setter Property="FontFamily" Value="Cambria, Segoe UI Emoji" />
        <Setter Property="FontSize" Value="30" />
        <Setter Property="FontWeight" Value="Bold" />
        <Setter Property="Foreground" Value="#FF1A1A1A" />
        <Setter Property="Margin" Value="0,16,0,10" />
    </Style>

    <Style x:Key="{x:Static markdig:Styles.Heading2StyleKey}" TargetType="{x:Type Paragraph}">
        <Setter Property="FontFamily" Value="Cambria, Segoe UI Emoji" />
        <Setter Property="FontSize" Value="24" />
        <Setter Property="FontWeight" Value="Bold" />
        <Setter Property="Foreground" Value="#FF1A1A1A" />
        <Setter Property="Margin" Value="0,14,0,8" />
    </Style>

    <Style x:Key="{x:Static markdig:Styles.Heading3StyleKey}" TargetType="{x:Type Paragraph}">
        <Setter Property="FontFamily" Value="Cambria, Segoe UI Emoji" />
        <Setter Property="FontSize" Value="20" />
        <Setter Property="FontWeight" Value="Bold" />
        <Setter Property="Foreground" Value="#FF1A1A1A" />
        <Setter Property="Margin" Value="0,12,0,6" />
    </Style>

    <Style x:Key="{x:Static markdig:Styles.Heading4StyleKey}" TargetType="{x:Type Paragraph}">
        <Setter Property="FontFamily" Value="Cambria, Segoe UI Emoji" />
        <Setter Property="FontSize" Value="17" />
        <Setter Property="FontWeight" Value="Bold" />
        <Setter Property="Foreground" Value="#FF1A1A1A" />
        <Setter Property="Margin" Value="0,10,0,6" />
    </Style>

    <Style x:Key="{x:Static markdig:Styles.Heading5StyleKey}" TargetType="{x:Type Paragraph}">
        <Setter Property="FontFamily" Value="Cambria, Segoe UI Emoji" />
        <Setter Property="FontSize" Value="15" />
        <Setter Property="FontWeight" Value="Bold" />
        <Setter Property="Foreground" Value="#FF1A1A1A" />
        <Setter Property="Margin" Value="0,10,0,6" />
    </Style>

    <Style x:Key="{x:Static markdig:Styles.Heading6StyleKey}" TargetType="{x:Type Paragraph}">
        <Setter Property="FontFamily" Value="Cambria, Segoe UI Emoji" />
        <Setter Property="FontSize" Value="13" />
        <Setter Property="FontWeight" Value="Bold" />
        <Setter Property="Foreground" Value="#FF555555" />
        <Setter Property="Margin" Value="0,10,0,6" />
    </Style>

    <!-- Body paragraphs: explicit sans-serif (safety; also inherited from document) -->
    <Style x:Key="{x:Static markdig:Styles.ParagraphStyleKey}" TargetType="{x:Type Paragraph}">
        <Setter Property="FontFamily" Value="Segoe UI, Segoe UI Emoji" />
        <Setter Property="Margin" Value="0,0,0,10" />
    </Style>

</ResourceDictionary>
